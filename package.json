{
  "name": "iobroker.daswetter",
  "version": "4.5.6",
  "description": "ioBroker DasWetter.com Adapter",
  "author": {
    "name": "René G.",
    "email": "info@rg-engineering.eu"
  },
  "homepage": "https://github.com/rg-engineering/ioBroker.daswetter",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "Smart Home",
    "wetter",
    "home automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rg-engineering/ioBroker.daswetter.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "axios": "^1.18.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "file:../adapter-dev/iobroker-adapter-dev-1.5.0.tgz",
    "@iobroker/build-tools": "^3.0.1",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.20",
    "typescript": "~6.0.3"
  },
  "main": "build/main.js",
  "bugs": {
    "url": "https://github.com/rg-engineering/ioBroker.daswetter/issues"
  },
  "scripts": {
    "test": "node node_modules/mocha/bin/mocha test/testAdapter.js --exit && node node_modules/mocha/bin/mocha test/testPackageFiles.js --exit",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "0-clean": "node tasks.js --0-clean",
    "1-npm": "node tasks.js --1-npm",
    "2-build": "node tasks.js --2-build",
    "3-copy": "node tasks.js --3-copy",
    "4-patch": "node tasks.js --4-patch",
    "build": "npm run build-backend && node tasks && npm pack",
    "build-backend": "tsc -p tsconfig.build.json",
    "npm": "npm i && cd src-admin && npm i -f"
  },
  "files": [
    "admin/",
    "admin{,/!(i18n)/**}/flat.txt",
    "admin/icons",
    "docs/",
    "!lib/",
    "!.vscode",
    "!.github",
    "!.git",
    "!.gitignore",
    "!.gitattributes",
    "!node_modules",
    "!tasks",
    "!.idea",
    "!test",
    "!typings",
    "!www/",
    "io-package.json",
    "LICENSE",
    "!main.js",
    "build/",
    "!readme.txt",
    "!docs/iconos.zip",
    "!docs/old_docu",
    "!docs/iconos"
  ],
  "readmeFilename": "README.md"
}
